# ========================================================================
# .env.example  ->  PLANTILLA. Copia a .env y rellena con tus valores.
# El archivo .env real NUNCA se sube a GitHub (esta en .gitignore).
# En EASYPANEL no usas este archivo: defines estas mismas variables
# en la seccion Environment del servicio.
# ========================================================================

# --- SECRETOS DEL EXCHANGE (Hyperliquid) ---
# WALLET_ADDRESS = tu direccion ETH PRINCIPAL (master account), con 0x.
# PRIVATE_KEY    = la private key de la API/Agent Wallet (NO la principal).
FREQTRADE__EXCHANGE__WALLET_ADDRESS=0xTU_WALLET_PRINCIPAL
FREQTRADE__EXCHANGE__PRIVATE_KEY=TU_PRIVATE_KEY_DEL_API_WALLET

# --- SECRETOS DE TELEGRAM ---
# TOKEN   = de @BotFather.  CHAT_ID = de @userinfobot.
FREQTRADE__TELEGRAM__TOKEN=TU_TOKEN_DE_TELEGRAM
FREQTRADE__TELEGRAM__CHAT_ID=TU_CHAT_ID

# --- PARAMETROS AJUSTABLES SIN REDEPLOY ---
# Margen por operacion en USDC (con leverage 2x, exposicion = x2).
FREQTRADE__STAKE_AMOUNT=50

# Operaciones simultaneas.
FREQTRADE__MAX_OPEN_TRADES=1

# dry_run: true = papel (sin dinero), false = LIVE (dinero real).
# DEJALO EN true hasta validar. Cambia a false solo cuando estes listo.
FREQTRADE__DRY_RUN=true
