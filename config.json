{
    "$schema": "https://schema.freqtrade.io/schema.json",

    "// COMO FUNCIONA": "Este config son los valores POR DEFECTO. Todo lo sensible (claves, token) y lo que quieras ajustar sin redeploy (stake_amount, dry_run, etc.) se sobreescribe con variables de entorno FREQTRADE__ en Easypanel. Ver README_GITHUB.md.",

    "// dry_run": "Por defecto TRUE (papel). En Easypanel pon FREQTRADE__DRY_RUN=false solo cuando vayas a live.",
    "dry_run": true,
    "dry_run_wallet": 1000,

    "max_open_trades": 1,
    "stake_currency": "USDC",
    "// stake_amount": "MARGEN por operacion. Sobreescribible con FREQTRADE__STAKE_AMOUNT. Con leverage 2x => exposicion = stake x 2. Con 50 => 100 USDC de exposicion; stop -4% => perdida ~4 USDC.",
    "stake_amount": 50,
    "tradable_balance_ratio": 0.99,
    "fiat_display_currency": "EUR",
    "timeframe": "1h",

    "// margen": "Futuros con margen AISLADO: cada posicion arriesga solo su propio margen, no toda la cuenta.",
    "trading_mode": "futures",
    "margin_mode": "isolated",

    "cancel_open_orders_on_exit": true,

    "unfilledtimeout": {
        "entry": 30,
        "exit": 30,
        "unit": "minutes"
    },

    "entry_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1
    },
    "exit_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1
    },

    "exchange": {
        "name": "hyperliquid",
        "// SECRETOS": "walletAddress y privateKey se inyectan con FREQTRADE__EXCHANGE__WALLET_ADDRESS y FREQTRADE__EXCHANGE__PRIVATE_KEY. Se dejan vacios aqui A PROPOSITO. NUNCA pongas claves reales en este archivo.",
        "walletAddress": "",
        "privateKey": "",
        "ccxt_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [
            "ZEC/USDC:USDC"
        ],
        "pair_blacklist": []
    },

    "pairlists": [
        {"method": "StaticPairList"}
    ],

    "telegram": {
        "// SECRETOS": "token y chat_id se inyectan con FREQTRADE__TELEGRAM__TOKEN y FREQTRADE__TELEGRAM__CHAT_ID.",
        "enabled": true,
        "token": "",
        "chat_id": "",
        "notification_settings": {
            "status": "on",
            "warning": "on",
            "startup": "on",
            "entry": "on",
            "entry_fill": "on",
            "entry_cancel": "on",
            "exit": {
                "roi": "on",
                "stop_loss": "on",
                "stoploss_on_exchange": "on",
                "trailing_stop_loss": "on",
                "exit_signal": "on",
                "force_exit": "on",
                "emergency_exit": "on"
            },
            "exit_fill": "on",
            "exit_cancel": "on",
            "protection_trigger": "on",
            "protection_trigger_global": "on"
        },
        "reload": true,
        "balance_dust_level": 0.01
    },

    "api_server": {
        "enabled": false,
        "listen_ip_address": "127.0.0.1",
        "listen_port": 8080,
        "verbosity": "error",
        "enable_openapi": false,
        "jwt_secret_key": "",
        "CORS_origins": [],
        "username": "freqtrader",
        "password": ""
    },

    "bot_name": "ZEC-MA10-bot",
    "initial_state": "running",
    "force_entry_enable": true,

    "internals": {
        "process_throttle_secs": 5
    }
}
